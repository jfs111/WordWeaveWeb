# ✦🕸️ Word Weave Web — Environment Variables
# Copy this file to .env and adjust values as needed.

# ── PostgreSQL ──
POSTGRES_USER=graphrag
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=graphrag

# ── JWT Authentication ──
JWT_SECRET=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# ── LLM (local, OpenAI-compatible) ──
LLM_URL=http://host.docker.internal:1234/v1
LLM_MODEL=openai/gpt-oss-20b

# ── Embedding ──
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Log level ──
LOG_LEVEL=INFO
